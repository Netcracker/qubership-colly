{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["dockerfile", "maven"],
  "lockFileMaintenance": {
    "enabled": false
  },
  "dependencyDashboard": true,
  "prConcurrentLimit": 1,
  "branchConcurrentLimit": 1,
  "timezone": "Europe/Moscow",
  "schedule": ["* 0-3 1,15 * *"],
  "packageRules": [
    {
      "description": "Maven and Docker: semver patch only — disable minor and major",
      "matchManagers": ["maven", "dockerfile"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Single PR grouping Dockerfile and Maven updates",
      "matchManagers": ["dockerfile", "maven"],
      "groupName": "dependency updates"
    }
  ]
}
